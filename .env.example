# Generate with Node.js:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
AUTH_SECRET=replace-with-a-secure-random-secret

# Google Cloud OAuth 2.0 Web application credentials
AUTH_GOOGLE_ID=replace-with-your-google-client-id
AUTH_GOOGLE_SECRET=replace-with-your-google-client-secret

# Local development URL. Change this to the production domain when deployed.
AUTH_URL=http://localhost:3000
